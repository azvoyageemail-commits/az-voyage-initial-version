# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/agency-travel
PAYLOAD_SECRET=agency-travel-super-secret-key-change-me

# URL where the CMS will run
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Allowed frontend origins for CORS/CSRF (comma-separated)
FRONTEND_ORIGINS=https://az-voyage.vercel.app

# Allowed request headers for CORS preflight (comma-separated)
CORS_HEADERS=Origin, X-Requested-With, Content-Type, Accept, Authorization, Cache-Control, Pragma

# Cloudinary (required to store uploads remotely)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=agency-travel
