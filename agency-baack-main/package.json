{
  "name": "agency-travel-cms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "build": "npm run generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "seed": "tsx src/seed.ts",
    "backfill:gallery": "tsx src/backfill-gallery-page.ts",
    "backfill:home": "tsx src/backfill-home-page.ts",
    "backfill:booking-process": "tsx src/backfill-booking-process-content.ts",
    "backfill:test-offers": "tsx src/backfill-offer-detail-sidebar-test-offers.ts",
    "backfill:destinations": "tsx src/backfill-destinations.ts",
    "generate:importmap": "cross-env CLOUDINARY_CLOUD_NAME=dummy CLOUDINARY_API_KEY=dummy CLOUDINARY_API_SECRET=dummy payload generate:importmap",
    "generate:types": "payload generate:types"
  },
  "dependencies": {
    "@jhb.software/payload-cloudinary-plugin": "^0.3.3",
    "@payloadcms/db-mongodb": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.0",
    "graphql": "^16.9.0",
    "mongodb": "^6.8.0",
    "next": "15.4.11",
    "payload": "3.80.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
